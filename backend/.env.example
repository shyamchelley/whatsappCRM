NODE_ENV=development
PORT=3001

# Database (leave blank for SQLite in dev)
DATABASE_URL=

# JWT
JWT_SECRET=change_this_to_a_random_256bit_secret
JWT_REFRESH_SECRET=change_this_to_another_random_256bit_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# WhatsApp Business Cloud API
WA_VERIFY_TOKEN=your_webhook_verify_token
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_whatsapp_access_token

# CORS
CORS_ORIGIN=http://localhost:5173

# Widget
SITE_TOKEN=your_site_token_for_widget
